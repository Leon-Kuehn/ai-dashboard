# Copy this file to .env and fill in your values.
# The dashboard, OpenClaw and Ollama all run on the same Proxmox VM,
# so 127.0.0.1 (localhost) is the correct default for all services.

# --- IMPORTANT: set this to your Proxmox VM's LAN IP ---
# This IP gets baked into the self-signed TLS certificate as a
# Subject Alternative Name so your browser trusts HTTPS on the LAN.
# Run: ip a   (look for the 192.168.x.x on your VM's network interface)
VM_IP=192.168.1.xxx

# Ollama – local inference server
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# OpenClaw – local AI agent
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000

# (Optional) Only change OLLAMA_HOST/OPENCLAW_HOST if you run
# Ollama or OpenClaw on a DIFFERENT machine than this dashboard.
# OLLAMA_HOST=192.168.1.xxx
# OPENCLAW_HOST=192.168.1.xxx
