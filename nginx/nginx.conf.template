worker_processes  auto;
error_log  /dev/stderr warn;
pid        /tmp/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    access_log    /dev/stdout;

    sendfile        on;
    keepalive_timeout  65;
    server_tokens   off;

    # Gzip
    gzip on;
    # text/html is compressed by default; do not repeat it in gzip_types.
    gzip_types text/css application/javascript application/json;
    gzip_min_length 256;

    # Upstream services (resolved via Docker internal DNS)
    upstream metrics_proxy {
        server metrics-proxy:9090;
    }

    # ── HTTP → HTTPS redirect ──────────────────────────────────
    server {
        listen 80;
        server_name _;
        return 301 https://$host$request_uri;
    }

    # ── HTTPS ─────────────────────────────────────────────────
    server {
        listen 443 ssl;
        server_name _;

        # If a client sends plain HTTP to the HTTPS port, redirect instead of 400.
        error_page 497 =301 https://$host$request_uri;

        ssl_certificate     /etc/nginx/ssl/cert.pem;
        ssl_certificate_key /etc/nginx/ssl/key.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        ssl_session_cache   shared:SSL:10m;
        ssl_session_timeout 10m;

        # Security headers
        add_header Content-Security-Policy  "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com https://r2cdn.perplexity.ai; img-src 'self' data:; connect-src 'self';" always;
        add_header X-Frame-Options          "DENY" always;
        add_header X-Content-Type-Options   "nosniff" always;
        add_header Referrer-Policy          "no-referrer" always;
        add_header Permissions-Policy       "camera=(), microphone=(), geolocation=()" always;

        root  /usr/share/nginx/html;
        index dashboard.html;

        # Disable directory listing
        autoindex off;

        # ── Static dashboard: GET / HEAD only ─────────────────
        location = / {
            if ($request_method !~ ^(GET|HEAD)$) { return 405; }
            try_files /dashboard.html =404;
        }

        location ~* \.html$ {
            if ($request_method !~ ^(GET|HEAD)$) { return 405; }
            try_files $uri /dashboard.html;
        }

        location / {
            if ($request_method !~ ^(GET|HEAD)$) { return 405; }
            try_files $uri $uri/ /dashboard.html;
        }

        # ── Proxy: metrics (read-only, GET only) ──────────────
        location /api/metrics {
            if ($request_method !~ ^(GET|HEAD)$) { return 405; }
            proxy_pass         http://metrics_proxy/metrics;
            proxy_set_header   Host $host;
            proxy_read_timeout 5s;
        }

        location /api/health {
            if ($request_method !~ ^(GET|HEAD)$) { return 405; }
            proxy_pass         http://metrics_proxy/health;
            proxy_set_header   Host $host;
            proxy_read_timeout 5s;
        }

        # ── Proxy: Ollama (full pass-through — chat needs POST) ─
        # Allowed: GET, HEAD, POST (streaming completions, tag list, etc.)
        # Blocked: PUT, DELETE, PATCH — Ollama has no need for these from the dashboard
        location /api/ollama/ {
            if ($request_method !~ ^(GET|HEAD|POST)$) { return 405; }
            resolver           127.0.0.11 valid=30s;
            set $ollama_upstream http://${OLLAMA_HOST}:${OLLAMA_PORT};
            proxy_pass         $ollama_upstream/;
            proxy_set_header   Host ${OLLAMA_HOST};
            proxy_set_header   X-Real-IP $remote_addr;
            # Streaming support (Ollama streams NDJSON)
            proxy_buffering    off;
            proxy_read_timeout 300s;
        }

        # ── Proxy: OpenClaw (full API — chat + tasks need POST/DELETE) ─
        # Allowed: GET, HEAD, POST, DELETE (task management + chat)
        # Blocked: PUT, PATCH — restrict to minimum needed
        location /api/openclaw/ {
            if ($request_method !~ ^(GET|HEAD|POST|DELETE)$) { return 405; }
            resolver           127.0.0.11 valid=30s;
            set $openclaw_upstream http://${OPENCLAW_HOST}:${OPENCLAW_PORT};
            proxy_pass         $openclaw_upstream/;
            proxy_set_header   Host ${OPENCLAW_HOST};
            proxy_set_header   X-Real-IP $remote_addr;
            proxy_buffering    off;
            proxy_read_timeout 120s;
        }
    }
}
